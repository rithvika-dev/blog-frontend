import { create } from "zustand";

import axios from "axios";

// Axios instance
const API = axios.create({
  baseURL:
    "https://blog-backend-1-jcc4.onrender.com",

  withCredentials: true,
});

export const useAuth = create(
  (set) => ({
    currentUser: null,

    loading: false,

    isAuthenticated: false,

    error: null,

    // LOGIN
    login: async (
      userCred
    ) => {
      try {
        // Start loading
        set({
          loading: true,

          currentUser: null,

          isAuthenticated: false,

          error: null,
        });

        // API call
        const res =
          await API.post(
            "/common-api/login",
            userCred
          );

        console.log(
          "Login Response:",
          res.data
        );

        // Success
        if (res.status === 200) {
          set({
            currentUser:
              res.data?.payload,

            loading: false,

            isAuthenticated: true,

            error: null,
          });
        }
      } catch (err) {
        console.log(
          "Login Error:",
          err
        );

        set({
          loading: false,

          isAuthenticated: false,

          currentUser: null,

          error:
            err.response?.data
              ?.error ||
            err.response?.data
              ?.message ||
            "Login failed",
        });
      }
    },

    // LOGOUT
    logout: async () => {
      try {
        set({
          loading: true,
        });

        // API call
        const res =
          await API.get(
            "/common-api/logout"
          );

        // Success
        if (res.status === 200) {
          set({
            currentUser: null,

            isAuthenticated: false,

            error: null,

            loading: false,
          });
        }
      } catch (err) {
        console.log(
          "Logout Error:",
          err
        );

        set({
          loading: false,

          isAuthenticated: false,

          currentUser: null,

          error:
            err.response?.data
              ?.error ||
            err.response?.data
              ?.message ||
            "Logout failed",
        });
      }
    },

    // CHECK AUTH
    checkAuth: async () => {
      try {
        set({
          loading: true,
        });

        const res =
          await API.get(
            "/common-api/check-auth"
          );

        console.log(
          "Auth Check:",
          res.data
        );

        // User authenticated
        if (res.status === 200) {
          set({
            currentUser:
              res.data.payload,

            isAuthenticated: true,

            loading: false,

            error: null,
          });
        }
      } catch (err) {
        console.log(
          "Auth Check Failed:",
          err
        );

        // Unauthorized
        if (
          err.response?.status ===
          401
        ) {
          set({
            currentUser: null,

            isAuthenticated: false,

            loading: false,

            error: null,
          });

          return;
        }

        // Other errors
        set({
          currentUser: null,

          isAuthenticated: false,

          loading: false,

          error:
            err.response?.data
              ?.error ||
            err.response?.data
              ?.message ||
            "Authentication failed",
        });
      }
    },
  })
);